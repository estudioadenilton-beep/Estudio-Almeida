# ==============================================
# Estúdio Almeida — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no Git.

# ── Supabase (público — seguro para frontend) ──────────────────────────────
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SEU-ANON-KEY-AQUI

# ── URL base da aplicação ──────────────────────────────────────────────────
# Usado para redirecionamentos de auth e compartilhamento de links
VITE_APP_URL=http://localhost:5173

# ── Ambiente ───────────────────────────────────────────────────────────────
# Valores: development | staging | production | test
VITE_APP_ENV=development

# ── Versão da aplicação ─────────────────────────────────────────────────────
# Usado pelo Sentry para associar erros a releases
# Em CI/CD, será o SHA do commit (VITE_APP_VERSION=$GITHUB_SHA)
VITE_APP_VERSION=0.0.0

# ── Sentry — Monitoramento de Erros ────────────────────────────────────────
# Obtenha gratuitamente em: https://sentry.io
# 1. Crie uma conta e um projeto do tipo "React"
# 2. Copie o DSN das configurações do projeto
# Deixar vazio desativa o Sentry (funcional, mas sem monitoramento remoto)
VITE_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# INSTRUÇÕES DE CONFIGURAÇÃO PARA PRODUÇÃO
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Configure as seguintes variáveis como Secrets no GitHub:
#    (Settings > Secrets and variables > Actions > New repository secret)
#
#    VITE_APP_URL = http://localhost:5173
#    VITE_SENTRY_DSN = DSN do projeto no Sentry
#    VERCEL_TOKEN = Token de deploy (https://vercel.com/account/tokens)
#    VERCEL_ORG_ID = ID da organização no Vercel
#    VERCEL_PROJECT_ID = ID do projeto no Vercel
#
# 2. Para obter VERCEL_ORG_ID e VERCEL_PROJECT_ID:
#    Execute localmente: npx vercel link
#    Os IDs serão salvos em .vercel/project.json
